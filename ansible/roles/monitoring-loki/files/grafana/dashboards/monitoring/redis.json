{
  "uid": "wiki-redis",
  "title": "Wiki Engine - Redis",
  "tags": ["redis", "wiki-engine", "monitoring", "phase11"],
  "timezone": "browser",
  "refresh": "15s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 100,
      "title": "Redis Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 1,
      "title": "메모리 사용률 (%)",
      "description": "maxmemory 256MB 대비 현재 사용량. 80% 이상 시 경고.",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "orange", "value": 0.8 },
              { "color": "red", "value": 0.9 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "redis_memory_used_bytes{job=\"redis\"} / redis_memory_max_bytes{job=\"redis\"}",
          "legendFormat": "Memory Usage",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "메모리 사용량 (절대값)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "redis_memory_used_bytes{job=\"redis\"}",
          "legendFormat": "Used",
          "refId": "A"
        },
        {
          "expr": "redis_memory_max_bytes{job=\"redis\"}",
          "legendFormat": "Max",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "title": "L2 캐시 히트율 (%)",
      "description": "Redis keyspace 히트율. 90% 이상 목표.",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.5 },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 0.9 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "redis_keyspace_hits_total{job=\"redis\"} / (redis_keyspace_hits_total{job=\"redis\"} + redis_keyspace_misses_total{job=\"redis\"})",
          "legendFormat": "Hit Rate",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "연결 수 / 키 수",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "redis_connected_clients{job=\"redis\"}",
          "legendFormat": "Clients",
          "refId": "A"
        },
        {
          "expr": "sum(redis_db_keys{job=\"redis\"})",
          "legendFormat": "Keys (전체)",
          "refId": "B"
        },
        {
          "expr": "redis_blocked_clients{job=\"redis\"}",
          "legendFormat": "Blocked",
          "refId": "C"
        }
      ]
    },
    {
      "id": 101,
      "title": "Operations",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false
    },
    {
      "id": 5,
      "title": "OPS (초당 명령 수)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(redis_commands_processed_total{job=\"redis\"}[1m])",
          "legendFormat": "Commands/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "히트 / 미스 추이",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(redis_keyspace_hits_total{job=\"redis\"}[1m])",
          "legendFormat": "Hits/s",
          "refId": "A"
        },
        {
          "expr": "rate(redis_keyspace_misses_total{job=\"redis\"}[1m])",
          "legendFormat": "Misses/s",
          "refId": "B"
        }
      ]
    },
    {
      "id": 7,
      "title": "Eviction 수 (per sec)",
      "description": "volatile-lru로 퇴거된 키. 급증 시 메모리 증설 검토.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(redis_evicted_keys_total{job=\"redis\"}[1m])",
          "legendFormat": "Evictions/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Slowlog 길이 / CPU 사용률",
      "description": "10ms 이상 느린 명령 누적 수. 5건 이상 지속 시 경고.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "redis_slowlog_length{job=\"redis\"}",
          "legendFormat": "Slowlog Length",
          "refId": "A"
        },
        {
          "expr": "rate(redis_cpu_sys_seconds_total{job=\"redis\"}[1m]) + rate(redis_cpu_user_seconds_total{job=\"redis\"}[1m])",
          "legendFormat": "Redis CPU (sys+user)",
          "refId": "B"
        }
      ]
    },
    {
      "id": 102,
      "title": "Network",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "collapsed": false
    },
    {
      "id": 9,
      "title": "네트워크 I/O (bytes/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "Bps", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(redis_net_input_bytes_total{job=\"redis\"}[1m])",
          "legendFormat": "Input",
          "refId": "A"
        },
        {
          "expr": "rate(redis_net_output_bytes_total{job=\"redis\"}[1m])",
          "legendFormat": "Output",
          "refId": "B"
        }
      ]
    },
    {
      "id": 10,
      "title": "Uptime / Redis Version",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 27 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "redis_uptime_in_seconds{job=\"redis\"}",
          "legendFormat": "Uptime",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39
}
