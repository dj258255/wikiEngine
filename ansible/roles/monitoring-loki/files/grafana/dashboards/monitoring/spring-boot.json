{
  "uid": "wiki-spring-boot",
  "title": "Wiki Engine - Spring Boot",
  "tags": ["spring-boot", "wiki-engine", "monitoring"],
  "timezone": "browser",
  "refresh": "15s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "HTTP 요청 - 평균 응답시간 (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_sum{application=\"wiki-engine\"}[1m]) / rate(http_server_requests_seconds_count{application=\"wiki-engine\"}[1m]) * 1000",
          "legendFormat": "{{method}} {{uri}} [{{status}}]",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP 요청 처리량 (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"wiki-engine\"}[1m])) by (uri)",
          "legendFormat": "{{uri}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "HTTP 응답시간 P95 / P99 (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"wiki-engine\"}[1m])) by (le)) * 1000",
          "legendFormat": "P95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{application=\"wiki-engine\"}[1m])) by (le)) * 1000",
          "legendFormat": "P99",
          "refId": "B"
        }
      ]
    },
    {
      "id": 4,
      "title": "HTTP 에러율 (4xx / 5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "color": { "mode": "palette-classic" }, "min": 0, "max": 1 },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"wiki-engine\", status=~\"4..\"}[1m])) / sum(rate(http_server_requests_seconds_count{application=\"wiki-engine\"}[1m]))",
          "legendFormat": "4xx",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"wiki-engine\", status=~\"5..\"}[1m])) / sum(rate(http_server_requests_seconds_count{application=\"wiki-engine\"}[1m]))",
          "legendFormat": "5xx",
          "refId": "B"
        }
      ]
    },
    {
      "id": 10,
      "title": "JVM",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "collapsed": false
    },
    {
      "id": 5,
      "title": "JVM Heap 메모리 사용량",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{application=\"wiki-engine\", area=\"heap\"}",
          "legendFormat": "Used - {{id}}",
          "refId": "A"
        },
        {
          "expr": "jvm_memory_max_bytes{application=\"wiki-engine\", area=\"heap\"}",
          "legendFormat": "Max - {{id}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 6,
      "title": "GC 일시정지 시간",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{application=\"wiki-engine\"}[1m])",
          "legendFormat": "{{action}} - {{cause}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "title": "HikariCP",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "collapsed": false
    },
    {
      "id": 7,
      "title": "HikariCP 커넥션 풀 상태",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "hikaricp_connections_active{application=\"wiki-engine\"}",
          "legendFormat": "{{pool}} Active",
          "refId": "A"
        },
        {
          "expr": "hikaricp_connections_idle{application=\"wiki-engine\"}",
          "legendFormat": "{{pool}} Idle",
          "refId": "B"
        },
        {
          "expr": "hikaricp_connections_pending{application=\"wiki-engine\"}",
          "legendFormat": "{{pool}} Pending",
          "refId": "C"
        },
        {
          "expr": "hikaricp_connections_max{application=\"wiki-engine\"}",
          "legendFormat": "{{pool}} Max",
          "refId": "D"
        }
      ]
    },
    {
      "id": 8,
      "title": "HikariCP 커넥션 획득 시간 (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(hikaricp_connections_acquire_seconds_sum{application=\"wiki-engine\"}[1m]) / rate(hikaricp_connections_acquire_seconds_count{application=\"wiki-engine\"}[1m]) * 1000",
          "legendFormat": "{{pool}} Avg Acquire",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "title": "시스템",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 },
      "collapsed": false
    },
    {
      "id": 9,
      "title": "프로세스 CPU 사용률",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "color": { "mode": "palette-classic" }, "min": 0, "max": 1 },
        "overrides": []
      },
      "targets": [
        {
          "expr": "process_cpu_usage{application=\"wiki-engine\"}",
          "legendFormat": "App CPU",
          "refId": "A"
        },
        {
          "expr": "system_cpu_usage{application=\"wiki-engine\"}",
          "legendFormat": "System CPU",
          "refId": "B"
        }
      ]
    },
    {
      "id": 13,
      "title": "JVM 스레드 수",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{application=\"wiki-engine\"}",
          "legendFormat": "Live",
          "refId": "A"
        },
        {
          "expr": "jvm_threads_peak_threads{application=\"wiki-engine\"}",
          "legendFormat": "Peak",
          "refId": "B"
        },
        {
          "expr": "jvm_threads_daemon_threads{application=\"wiki-engine\"}",
          "legendFormat": "Daemon",
          "refId": "C"
        }
      ]
    },
    {
      "id": 20,
      "title": "Tiered Cache (L1/L2/Origin)",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 43 },
      "collapsed": false
    },
    {
      "id": 21,
      "title": "L1 / L2 / Origin 히트 비율",
      "description": "TieredCacheService 3계층 캐시 히트 분포. Origin이 높으면 캐시 효과 부족.",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 44 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "pieType": "donut"
      },
      "targets": [
        {
          "expr": "sum by (level) (rate(tiered_cache_total{application=\"wiki-engine\"}[5m]))",
          "legendFormat": "{{level}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 22,
      "title": "캐시 리전별 히트 추이",
      "description": "searchResults / postDetail 별 L1/L2/Origin 추이",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 44 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (region, level) (rate(tiered_cache_total{application=\"wiki-engine\"}[1m]))",
          "legendFormat": "{{region}} - {{level}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 23,
      "title": "Origin 도달률 (Lucene/MySQL 접근)",
      "description": "L1+L2 미스 → Lucene/MySQL 직접 접근 빈도. CPU 부하와 상관관계.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 44 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (region) (rate(tiered_cache_total{application=\"wiki-engine\", level=\"origin\"}[1m]))",
          "legendFormat": "{{region}} → origin",
          "refId": "A"
        }
      ]
    },
    {
      "id": 30,
      "title": "Lettuce (Redis 클라이언트 레이턴시)",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 52 },
      "collapsed": false
    },
    {
      "id": 31,
      "title": "Lettuce 커맨드 P95 레이턴시 (ms)",
      "description": "앱→Redis 왕복 P95. SLA 5ms 이내 목표.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 53 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(lettuce_seconds_bucket{application=\"wiki-engine\"}[5m])) by (le)) * 1000",
          "legendFormat": "P95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(lettuce_seconds_bucket{application=\"wiki-engine\"}[5m])) by (le)) * 1000",
          "legendFormat": "P99",
          "refId": "B"
        }
      ]
    },
    {
      "id": 32,
      "title": "Lettuce 커맨드별 레이턴시 (ms)",
      "description": "GET vs SET 비교. 특정 커맨드가 느리면 키 크기 또는 네트워크 문제.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 53 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(lettuce_seconds_bucket{application=\"wiki-engine\"}[5m])) by (le, db_operation)) * 1000",
          "legendFormat": "{{db_operation}} P95",
          "refId": "A"
        }
      ]
    },
  ],
  "schemaVersion": 39
}
