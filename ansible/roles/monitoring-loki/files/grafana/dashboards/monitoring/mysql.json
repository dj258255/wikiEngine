{
  "uid": "wiki-mysql",
  "title": "Wiki Engine - MySQL",
  "tags": ["mysql", "wiki-engine", "monitoring"],
  "timezone": "browser",
  "refresh": "15s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "MySQL QPS (Queries Per Second)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(mysql_global_status_queries{job=\"mysql-exporter\"}[1m])",
          "legendFormat": "Primary QPS",
          "refId": "A"
        },
        {
          "expr": "rate(mysql_global_status_queries{job=\"mysql-replica\"}[1m])",
          "legendFormat": "Replica QPS",
          "refId": "B"
        }
      ]
    },
    {
      "id": 2,
      "title": "MySQL 커넥션 수",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "mysql_global_status_threads_connected{job=\"mysql-exporter\"}",
          "legendFormat": "Primary Connected",
          "refId": "A"
        },
        {
          "expr": "mysql_global_status_threads_connected{job=\"mysql-replica\"}",
          "legendFormat": "Replica Connected",
          "refId": "B"
        },
        {
          "expr": "mysql_global_status_threads_running{job=\"mysql-exporter\"}",
          "legendFormat": "Primary Running",
          "refId": "C"
        },
        {
          "expr": "mysql_global_status_threads_running{job=\"mysql-replica\"}",
          "legendFormat": "Replica Running",
          "refId": "D"
        }
      ]
    },
    {
      "id": 3,
      "title": "InnoDB 버퍼 풀 히트율 (%)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.95 },
              { "color": "green", "value": 0.99 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "1 - (rate(mysql_global_status_innodb_buffer_pool_reads[5m]) / rate(mysql_global_status_innodb_buffer_pool_read_requests[5m]))",
          "legendFormat": "Hit Rate",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "InnoDB 버퍼 풀 사용량",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "mysql_global_status_innodb_buffer_pool_bytes_data",
          "legendFormat": "Data",
          "refId": "A"
        },
        {
          "expr": "mysql_global_variables_innodb_buffer_pool_size",
          "legendFormat": "Pool Size",
          "refId": "B"
        }
      ]
    },
    {
      "id": 5,
      "title": "Slow Queries (누적)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 100 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "mysql_global_status_slow_queries",
          "legendFormat": "Slow Queries",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Table Locks",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(mysql_global_status_table_locks_waited[5m])",
          "legendFormat": "Locks Waited/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "MySQL 명령 유형별 처리량",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(mysql_global_status_commands_total{command=~\"select|insert|update|delete\"}[1m])",
          "legendFormat": "{{command}}/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "InnoDB Row Lock 대기시간",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(mysql_global_status_innodb_row_lock_time[1m]) / 1000",
          "legendFormat": "Row Lock Time/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "InnoDB Row 연산",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(mysql_global_status_innodb_system_rows_read[1m])",
          "legendFormat": "Rows Read/s",
          "refId": "A"
        },
        {
          "expr": "rate(mysql_global_status_innodb_system_rows_inserted[1m])",
          "legendFormat": "Rows Inserted/s",
          "refId": "B"
        },
        {
          "expr": "rate(mysql_global_status_innodb_system_rows_updated[1m])",
          "legendFormat": "Rows Updated/s",
          "refId": "C"
        },
        {
          "expr": "rate(mysql_global_status_innodb_system_rows_deleted[1m])",
          "legendFormat": "Rows Deleted/s",
          "refId": "D"
        }
      ]
    }
    ,{
      "id": 20,
      "title": "Replication (Phase 12)",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "collapsed": false
    },
    {
      "id": 21,
      "title": "Replication Lag (초)",
      "description": "Replica가 Primary 대비 얼마나 뒤처져 있는지. 10초 이상 시 경고.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          },
          "custom": { "thresholdsStyle": { "mode": "line+area" } }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "mysql_slave_status_seconds_behind_master{job=\"mysql-replica\"}",
          "legendFormat": "Seconds Behind Primary",
          "refId": "A"
        }
      ]
    },
    {
      "id": 22,
      "title": "Replication Thread 상태",
      "description": "IO/SQL Thread 동작 여부. 1=Running, 0=Stopped.",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "STOPPED", "color": "red" }, "1": { "text": "Running", "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "mysql_slave_status_slave_io_running{job=\"mysql-replica\"}",
          "legendFormat": "IO Thread",
          "refId": "A"
        },
        {
          "expr": "mysql_slave_status_slave_sql_running{job=\"mysql-replica\"}",
          "legendFormat": "SQL Thread",
          "refId": "B"
        }
      ]
    },
    {
      "id": 23,
      "title": "Primary vs Replica 명령 유형별 비교",
      "description": "Primary에는 INSERT/UPDATE/DELETE, Replica에는 SELECT가 집중되어야 정상.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(mysql_global_status_commands_total{job=\"mysql-exporter\", command=\"select\"}[1m])",
          "legendFormat": "Primary SELECT/s",
          "refId": "A"
        },
        {
          "expr": "rate(mysql_global_status_commands_total{job=\"mysql-replica\", command=\"select\"}[1m])",
          "legendFormat": "Replica SELECT/s",
          "refId": "B"
        },
        {
          "expr": "rate(mysql_global_status_commands_total{job=\"mysql-exporter\", command=~\"insert|update|delete\"}[1m])",
          "legendFormat": "Primary Write/s",
          "refId": "C"
        }
      ]
    },
    {
      "id": 10,
      "title": "Slow Query 로그 (1초 이상)",
      "description": "Query_time >= 1초인 쿼리만 표시. 실제 성능 병목을 찾는 용도.",
      "type": "logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 32 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "expr": "{job=\"mysql-slow-query\", query_time=~\"[1-9].*\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "title": "Slow Query 로그 (전체)",
      "description": "인덱스 미사용 쿼리 포함. 전체 현황 파악용.",
      "type": "logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 44 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "expr": "{job=\"mysql-slow-query\"}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39
}
