# Promtail - App Server → Loki
server:
  http_listen_port: 9080
  grpc_listen_port: 0

positions:
  filename: /tmp/positions.yaml

clients:
  - url: http://{{ hostvars["monitoring-loki"].private_ip }}:3100/loki/api/v1/push

scrape_configs:
  - job_name: docker
    docker_sd_configs:
      - host: unix:///var/run/docker.sock
        refresh_interval: 5s
    relabel_configs:
      - source_labels: ['__meta_docker_container_name']
        regex: '/(.*)'
        target_label: 'container'
    pipeline_stages:
      - multiline:
          firstline: '^\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{3}'
          max_wait_time: 3s

  - job_name: mysql-slow-query
    static_configs:
      - targets: [localhost]
        labels:
          job: mysql-slow-query
          host: app-server
          level: warning
          __path__: /var/log/mysql/slow.log
    pipeline_stages:
      - multiline:
          firstline: '^# Time:'
          max_wait_time: 3s
      # mysql-exporter 내부 쿼리 제거 (information_schema, performance_schema)
      - drop:
          expression: 'information_schema|performance_schema'
      # Query_time, Rows_examined 추출 → Grafana에서 필터 가능
      - regex:
          expression: 'Query_time:\s+(?P<query_time>[\d.]+)\s+Lock_time:\s+(?P<lock_time>[\d.]+)\s+Rows_sent:\s+(?P<rows_sent>\d+)\s+Rows_examined:\s+(?P<rows_examined>\d+)'
      - labels:
          query_time:
          rows_examined:
