# ARM App Server ({{ app_server_host }})
# Nginx + App + MySQL + Redis + Alloy + cAdvisor + Node Exporter + MySQL Exporter + Redis Exporter
#
# 사용법: docker compose --env-file .env.prod up -d

services:
  nginx:
    image: {{ nginx_image }}
    container_name: wiki-nginx-prod
    restart: always
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ./nginx/nginx.conf:/etc/nginx/conf.d/default.conf:ro,Z
      - ./certbot/www:/var/www/certbot:ro
      - ./certbot/certs:/etc/letsencrypt:ro
    deploy:
      resources:
        limits:
          memory: {{ app_nginx_memory_limit }}
    depends_on:
      - app
    networks:
      - wiki-net

  mysql:
    image: {{ mysql_image }}
    container_name: wiki-mysql-prod
    restart: always
    environment:
      MYSQL_ROOT_PASSWORD: ${MYSQL_ROOT_PASSWORD}
      MYSQL_DATABASE: ${DB_NAME}
      MYSQL_USER: ${DB_USERNAME}
      MYSQL_PASSWORD: ${DB_PASSWORD}
    # MySQL 포트: localhost(SSH 터널) + private IP(Replica 연결) 양쪽 허용
    ports:
      - "127.0.0.1:3306:3306"
      - "{{ hostvars['app-arm'].private_ip }}:3306:3306"
    volumes:
      - mysql_data:/var/lib/mysql
      - mysql_logs:/var/log/mysql
      - ./init-exporter-user.sh:/docker-entrypoint-initdb.d/01-exporter-user.sh:ro
    deploy:
      resources:
        limits:
          memory: {{ mysql_memory_limit }}
    command: >
      --character-set-server=utf8mb4
      --collation-server=utf8mb4_unicode_ci
      --ngram-token-size=2
      --innodb-buffer-pool-size=2G
      --slow-query-log=ON
      --slow-query-log-file=/var/log/mysql/slow.log
      --long-query-time=${MYSQL_SLOW_QUERY_TIME}
      --log-queries-not-using-indexes=ON
      --performance-schema=ON
      --server-id=1
      --log-bin=mysql-bin
      --binlog-format=ROW
      --binlog-expire-logs-seconds=604800
      --gtid-mode=ON
      --enforce-gtid-consistency=ON
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - wiki-net

  app:
    image: ${APP_IMAGE}
    container_name: wiki-app-prod
    restart: always
    environment:
      SPRING_PROFILES_ACTIVE: ${ENVIRONMENT}
      DB_HOST: mysql
      DB_PORT: 3306
      DB_NAME: ${DB_NAME}
      DB_USERNAME: ${DB_USERNAME}
      DB_PASSWORD: ${DB_PASSWORD}
      DB_PRIMARY_HOST: ${DB_PRIMARY_HOST}
      DB_REPLICA_HOST: ${DB_REPLICA_HOST}
      DB_PRIMARY_POOL_SIZE: ${DB_PRIMARY_POOL_SIZE}
      DB_REPLICA_POOL_SIZE: ${DB_REPLICA_POOL_SIZE}
      JWT_SECRET: ${JWT_SECRET}
      JWT_EXPIRATION: ${JWT_EXPIRATION}
      SERVER_PORT: 8080
      LOG_LEVEL: ${LOG_LEVEL}
      HIBERNATE_BATCH_SIZE: ${HIBERNATE_BATCH_SIZE}
      JPA_DDL_AUTO: ${JPA_DDL_AUTO}
      JPA_SHOW_SQL: ${JPA_SHOW_SQL}
      FLYWAY_ENABLED: ${FLYWAY_ENABLED}
      HIBERNATE_STATISTICS: ${HIBERNATE_STATISTICS}
      COOKIE_SECURE: ${COOKIE_SECURE}
      CORS_ALLOWED_ORIGINS: ${CORS_ALLOWED_ORIGINS}
      ACTUATOR_ENDPOINTS: ${ACTUATOR_ENDPOINTS}
      HEALTH_SHOW_DETAILS: ${HEALTH_SHOW_DETAILS}
      LUCENE_INDEX_PATH: ${LUCENE_INDEX_PATH}
      LUCENE_BATCH_SIZE: ${LUCENE_BATCH_SIZE}
      JAVA_OPTS: ${JAVA_OPTS}
      REDIS_HOST: redis
      REDIS_PORT: 6379
      REDIS_PASSWORD: ${REDIS_PASSWORD}
    ports:
      - "8080:8080"  # Prometheus 스크래핑용 (nginx는 80/443)
    volumes:
      - lucene_index:/data/lucene  # Lucene 인덱스 (컨테이너 재생성 시에도 보존)
    deploy:
      resources:
        limits:
          memory: {{ app_memory_limit }}
    depends_on:
      mysql:
        condition: service_healthy
      redis:
        condition: service_healthy
    networks:
      - wiki-net

  redis:
    image: {{ redis_image }}
    container_name: wiki-redis-prod
    restart: always
    volumes:
      - redis_data:/data
    command: >
      redis-server
      --maxmemory {{ redis_maxmemory }}
      --maxmemory-policy volatile-lru
      --requirepass ${REDIS_PASSWORD}
      --slowlog-log-slower-than 10000
      --slowlog-max-len 128
    deploy:
      resources:
        limits:
          memory: {{ redis_memory_limit }}
    healthcheck:
      test: ["CMD", "redis-cli", "-a", "${REDIS_PASSWORD}", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - wiki-net

  redis-exporter:
    image: {{ redis_exporter_image }}
    container_name: wiki-redis-exporter-prod
    restart: always
    environment:
      REDIS_ADDR: redis:6379
      REDIS_PASSWORD: ${REDIS_PASSWORD}
    ports:
      - "9121:9121"
    deploy:
      resources:
        limits:
          memory: {{ redis_exporter_memory_limit }}
    depends_on:
      redis:
        condition: service_healthy
    networks:
      - wiki-net

  mysql-exporter:
    image: {{ mysqld_exporter_image }}
    container_name: wiki-mysql-exporter-prod
    restart: always
    environment:
      MYSQLD_EXPORTER_PASSWORD: ${MYSQL_EXPORTER_PASSWORD}
    command:
      - "--mysqld.address=mysql:3306"
      - "--mysqld.username=${MYSQL_EXPORTER_USERNAME}"
    ports:
      - "9104:9104"
    deploy:
      resources:
        limits:
          memory: {{ mysqld_exporter_memory_limit }}
    depends_on:
      mysql:
        condition: service_healthy
    networks:
      - wiki-net

  alloy:
    image: {{ alloy_image }}
    container_name: wiki-alloy-prod
    restart: always
    volumes:
      - ./alloy/config.alloy:/etc/alloy/config.alloy:Z
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - /var/lib/docker/containers:/var/lib/docker/containers:ro
      - mysql_logs:/var/log/mysql:ro
      - alloy_data:/var/lib/alloy/data
    command:
      - run
      - /etc/alloy/config.alloy
      - --storage.path=/var/lib/alloy/data
    deploy:
      resources:
        limits:
          memory: {{ alloy_memory_limit }}
    networks:
      - wiki-net

  node-exporter:
    image: {{ node_exporter_image }}
    container_name: wiki-node-exporter-prod
    restart: always
    pid: host
    command:
      - "--path.rootfs=/host"
    volumes:
      - /:/host:ro,rslave
    ports:
      - "9100:9100"
    deploy:
      resources:
        limits:
          memory: {{ node_exporter_memory_limit }}
    networks:
      - wiki-net

  cadvisor:
    image: {{ cadvisor_image }}
    container_name: wiki-cadvisor-prod
    restart: always
    privileged: true
    ports:
      - "8081:8080"
    volumes:
      - /:/rootfs:ro
      - /var/run:/var/run:ro
      - /sys:/sys:ro
      - /var/lib/docker/:/var/lib/docker:ro
      - /dev/disk/:/dev/disk:ro
    deploy:
      resources:
        limits:
          memory: {{ cadvisor_memory_limit }}
    networks:
      - wiki-net

volumes:
  mysql_data:
  mysql_logs:
  lucene_index:
  redis_data:
  alloy_data:

networks:
  wiki-net:
    driver: bridge
