// Grafana Alloy - App Server 1 → Loki
// Docker 컨테이너 로그 + MySQL Slow Query 로그 수집

// ============================================================
// 1. Docker 컨테이너 로그 수집
// ============================================================

discovery.docker "containers" {
  host = "unix:///var/run/docker.sock"
  refresh_interval = "5s"
}

discovery.relabel "containers" {
  targets = discovery.docker.containers.targets

  rule {
    source_labels = ["__meta_docker_container_name"]
    regex         = "/(.*)"
    target_label  = "container"
  }
}

loki.source.docker "containers" {
  host       = "unix:///var/run/docker.sock"
  targets    = discovery.relabel.containers.output
  forward_to = [loki.process.multiline_docker.receiver]
}

loki.process "multiline_docker" {
  stage.multiline {
    firstline = "^\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2}\\.\\d{3}"
    max_wait_time = "3s"
  }

  forward_to = [loki.write.default.receiver]
}

// ============================================================
// 2. MySQL Slow Query 로그 수집
// ============================================================

local.file_match "mysql_slow" {
  path_targets = [{
    __path__ = "/var/log/mysql/slow.log",
    job      = "mysql-slow-query",
    level    = "warning",
  }]
}

loki.source.file "mysql_slow" {
  targets    = local.file_match.mysql_slow.targets
  forward_to = [loki.process.mysql_slow.receiver]
}

loki.process "mysql_slow" {
  stage.multiline {
    firstline = "^# Time:"
    max_wait_time = "3s"
  }

  stage.drop {
    expression = "information_schema|performance_schema"
  }

  stage.regex {
    expression = "Query_time:\\s+(?P<query_time>[\\d.]+)\\s+Lock_time:\\s+(?P<lock_time>[\\d.]+)\\s+Rows_sent:\\s+(?P<rows_sent>\\d+)\\s+Rows_examined:\\s+(?P<rows_examined>\\d+)"
  }

  stage.labels {
    values = {
      query_time    = "",
      rows_examined = "",
    }
  }

  forward_to = [loki.write.default.receiver]
}

// ============================================================
// 3. JVM GC 로그 수집 (Phase: JVM 튜닝 실험)
// ============================================================

local.file_match "gc_logs" {
  path_targets = [{
    __path__ = "/var/log/gc/gc-*.log",
    job      = "jvm-gc",
  }]
}

loki.source.file "gc_logs" {
  targets    = local.file_match.gc_logs.targets
  forward_to = [loki.write.default.receiver]
}

// ============================================================
// 4. Loki 전송 엔드포인트
// ============================================================

loki.write "default" {
  external_labels = {
    "host" = "app-server-1",
    "env"  = "production",
  }
  endpoint {
    url = "http://{{ hostvars['monitoring-loki'].private_ip }}:3100/loki/api/v1/push"
  }
}
