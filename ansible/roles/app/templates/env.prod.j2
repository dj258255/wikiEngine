# ARM App Server 운영 환경 변수 (Ansible 생성)
# {{ ansible_date_time.iso8601 }}

ENVIRONMENT=prod

APP_IMAGE={{ app_image }}

# Database — Primary/Replica (Phase 12)
DB_NAME={{ db_name }}
DB_USERNAME={{ db_username }}
DB_PASSWORD={{ db_password }}
DB_HOST=mysql
DB_PORT=3306
DB_PRIMARY_HOST=mysql
DB_REPLICA_HOST={{ hostvars['app-arm-2'].private_ip }}
DB_PRIMARY_POOL_SIZE=3
DB_REPLICA_POOL_SIZE=15

# MySQL
MYSQL_ROOT_PASSWORD={{ db_root_password }}
MYSQL_SLOW_QUERY_TIME={{ mysql_slow_query_time }}
MYSQL_EXPORTER_USERNAME={{ mysql_exporter_username }}
MYSQL_EXPORTER_PASSWORD={{ mysql_exporter_password }}

# JWT
JWT_SECRET={{ jwt_secret }}
JWT_EXPIRATION={{ jwt_expiration }}

# JPA / Flyway
JPA_DDL_AUTO={{ jpa_ddl_auto }}
FLYWAY_ENABLED={{ flyway_enabled }}
JPA_SHOW_SQL={{ jpa_show_sql }}
HIBERNATE_BATCH_SIZE={{ hibernate_batch_size }}
HIBERNATE_STATISTICS={{ hibernate_statistics }}

# Cookie
COOKIE_SECURE={{ cookie_secure }}

# CORS
CORS_ALLOWED_ORIGINS={{ cors_allowed_origins }}

# Actuator
ACTUATOR_ENDPOINTS={{ actuator_endpoints }}
HEALTH_SHOW_DETAILS={{ health_show_details }}

# Lucene
LUCENE_INDEX_PATH={{ lucene_index_path }}
LUCENE_BATCH_SIZE={{ lucene_batch_size }}
LUCENE_MODE=primary

# JVM
# java_opts: group_vars/all.yml에서 주입 (실험 시 -e "java_opts=..."로 override 가능)
# 추가 옵션:
#   - GC log: /var/log/gc/gc-*.log (Alloy가 Loki로 수집)
#   - NMT summary: jcmd VM.native_memory summary 로 Off-heap breakdown 확인
#   - HeapDumpOnOOM: OOM 시 /var/log/gc/에 .hprof 자동 저장 (Eclipse MAT 분석용)
JAVA_OPTS={{ java_opts }} -Xlog:gc*:file=/var/log/gc/gc-%t.log:time,uptime,level,tags:filecount=5,filesize=100M -XX:NativeMemoryTracking=summary -XX:+HeapDumpOnOutOfMemoryError -XX:HeapDumpPath=/var/log/gc/

# Tomcat
TOMCAT_MAX_THREADS={{ tomcat_max_threads | default(200) }}
TOMCAT_MIN_THREADS={{ tomcat_min_threads | default(10) }}
TOMCAT_ACCEPT_COUNT={{ tomcat_accept_count | default(100) }}

# Server
SERVER_PORT={{ server_port | default(8080) }}

# Redis (Phase 11)
REDIS_PASSWORD={{ redis_password }}

# Kafka CDC (Phase 14-3)
# 서버 1은 Kafka가 다른 서버이므로 private IP + 외부 포트 사용
KAFKA_BOOTSTRAP_SERVERS={{ hostvars['app-arm-2'].private_ip }}:9094

# HikariCP
HIKARI_LEAK_DETECTION_THRESHOLD=10000

# Phase 21: Spring AI + Gemini (RAG)
GEMINI_API_KEY={{ gemini_api_key }}

# Phase 19: LTR (Learning to Rank)
LTR_ENABLED={{ LTR_ENABLED }}

# Logging
LOG_LEVEL={{ log_level }}
