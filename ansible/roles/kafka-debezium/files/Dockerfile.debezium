FROM quay.io/debezium/connect:3.4

# MySQL 커넥터만 남기고 불필요한 커넥터 삭제 (ARM 2vCPU 환경 플러그인 스캔 OOM 방지)
USER root
RUN rm -rf /kafka/connect/debezium-connector-cockroachdb \
           /kafka/connect/debezium-connector-db2 \
           /kafka/connect/debezium-connector-ibmi \
           /kafka/connect/debezium-connector-informix \
           /kafka/connect/debezium-connector-jdbc \
           /kafka/connect/debezium-connector-mariadb \
           /kafka/connect/debezium-connector-mongodb \
           /kafka/connect/debezium-connector-oracle \
           /kafka/connect/debezium-connector-postgres \
           /kafka/connect/debezium-connector-spanner \
           /kafka/connect/debezium-connector-sqlserver \
           /kafka/connect/debezium-connector-vitess

# JMX Prometheus Exporter (CDC lag 모니터링)
RUN mkdir -p /kafka/etc && \
    curl -fSL --retry 3 --retry-delay 2 \
    -o /kafka/etc/jmx_prometheus_javaagent.jar \
    https://repo1.maven.org/maven2/io/prometheus/jmx/jmx_prometheus_javaagent/1.0.1/jmx_prometheus_javaagent-1.0.1.jar && \
    chmod 644 /kafka/etc/jmx_prometheus_javaagent.jar
USER kafka

COPY jmx-exporter/debezium-jmx-config.yml /kafka/etc/jmx-config.yml

ENV KAFKA_OPTS="-javaagent:/kafka/etc/jmx_prometheus_javaagent.jar=7072:/kafka/etc/jmx-config.yml"
