# Prometheus - 멀티서버 스크래핑 설정 (Private IP)
global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  # Spring Boot App (ARM)
  - job_name: 'spring-boot'
    metrics_path: '/actuator/prometheus'
    static_configs:
      - targets: ['{{ hostvars["app-arm"].private_ip }}:8080']

  # Spring Boot App 2 (ARM Server 2, Phase 13)
  - job_name: 'spring-boot-2'
    metrics_path: '/actuator/prometheus'
    static_configs:
      - targets: ['{{ hostvars["app-arm-2"].private_ip }}:8080']

  # MySQL Exporter (ARM)
  - job_name: 'mysql-exporter'
    static_configs:
      - targets: ['{{ hostvars["app-arm"].private_ip }}:9104']

  # cAdvisor (ARM - container metrics)
  - job_name: 'cadvisor'
    static_configs:
      - targets: ['{{ hostvars["app-arm"].private_ip }}:8081']

  # MySQL Exporter — Replica (ARM Server 2, Phase 12)
  - job_name: 'mysql-replica'
    static_configs:
      - targets: ['{{ hostvars["app-arm-2"].private_ip }}:9104']

  # Redis Exporter — 기존 단일 인스턴스 (직접 스크래핑)
  - job_name: 'redis'
    static_configs:
      - targets: ['{{ hostvars["app-arm"].private_ip }}:9121']

  # Redis Exporter — 샤드 3개 (multi-target 패턴, Phase 15)
  - job_name: 'redis-shards'
    static_configs:
      - targets:
          - 'redis://{{ hostvars["app-arm"].private_ip }}:{{ redis_shard1_port }}'
          - 'redis://{{ hostvars["app-arm-2"].private_ip }}:{{ redis_shard2_port }}'
          - 'redis://{{ hostvars["app-arm-2"].private_ip }}:{{ redis_shard3_port }}'
    metrics_path: /scrape
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: '{{ hostvars["app-arm"].private_ip }}:9121'

  # Nginx Exporter — RPS, 4xx/5xx, 커넥션 수
  - job_name: 'nginx'
    static_configs:
      - targets: ['{{ hostvars["app-arm"].private_ip }}:9113']

  # Kafka Exporter — Consumer lag, 토픽 메트릭 (Phase 14-3)
  - job_name: 'kafka-exporter'
    static_configs:
      - targets: ['{{ hostvars["app-arm-2"].private_ip }}:9308']

  # Debezium JMX Exporter — CDC lag, 커넥터 상태 (Phase 14-3)
  - job_name: 'debezium-jmx'
    static_configs:
      - targets: ['{{ hostvars["app-arm-2"].private_ip }}:7072']

  # Node Exporter (all servers)
  - job_name: 'node-exporter'
    static_configs:
      - targets: ['{{ hostvars["app-arm"].private_ip }}:9100']
        labels:
          server: 'app-arm'
      - targets: ['{{ hostvars["app-arm-2"].private_ip }}:9100']
        labels:
          server: 'app-arm-2'
      - targets: ['{{ hostvars["monitoring-loki"].private_ip }}:9100']
        labels:
          server: 'monitoring-loki'
      - targets: ['{{ hostvars["monitoring-prometheus"].private_ip }}:9100']
        labels:
          server: 'monitoring-prometheus'
