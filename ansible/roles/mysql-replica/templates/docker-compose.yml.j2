# 서버 2: MySQL Replica + App 2 + Alloy (Phase 12~13)
# Phase 12: MySQL Replica (읽기 부하 분산)
# Phase 13: App 2 (CPU 부하 분산) + Alloy (로그 수집)

services:
  mysql-replica:
    image: {{ mysql_image }}
    container_name: wiki-mysql-replica
    restart: always
    environment:
      MYSQL_ROOT_PASSWORD: ${MYSQL_ROOT_PASSWORD}
    ports:
      - "3306:3306"
    volumes:
      - mysql_replica_data:/var/lib/mysql
    deploy:
      resources:
        limits:
          memory: {{ mysql_replica_memory_limit }}
    # Note: read-only/super-read-only는 초기화 완료 후 START REPLICA 시점에 SET GLOBAL로 활성화.
    # Docker entrypoint 초기화(root 비밀번호 설정)가 super-read-only와 충돌하므로 command에서 제외.
    command: >
      --character-set-server=utf8mb4
      --collation-server=utf8mb4_unicode_ci
      --innodb-buffer-pool-size=2G
      --performance-schema=ON
      --server-id=2
      --relay-log=relay-bin
      --log-replica-updates=ON
      --gtid-mode=ON
      --enforce-gtid-consistency=ON
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - wiki-net

  # Phase 13: App 2 (Lucene Replica 모드)
  app:
    image: {{ app_image }}
    container_name: wiki-app-prod-2
    restart: always
    env_file:
      - .env.prod
    ports:
      - "8080:8080"
    volumes:
      - lucene_index:/data/lucene
    deploy:
      resources:
        limits:
          memory: {{ app_memory_limit }}
    healthcheck:
      test: ["CMD", "curl", "-sf", "http://localhost:8080/actuator/health"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 120s
    depends_on:
      mysql-replica:
        condition: service_healthy
    networks:
      - wiki-net

  # Phase 13: Alloy (App 2 로그 → Loki)
  alloy:
    image: {{ alloy_image }}
    container_name: wiki-alloy-prod-2
    restart: always
    volumes:
      - ./alloy-config.alloy:/etc/alloy/config.alloy:ro
      - /var/run/docker.sock:/var/run/docker.sock:ro
    command:
      - run
      - /etc/alloy/config.alloy
    deploy:
      resources:
        limits:
          memory: {{ alloy_memory_limit }}
    networks:
      - wiki-net

  mysql-exporter:
    image: {{ mysqld_exporter_image }}
    container_name: wiki-mysql-exporter-replica
    restart: always
    environment:
      MYSQLD_EXPORTER_PASSWORD: ${MYSQL_EXPORTER_PASSWORD}
    command:
      - "--mysqld.address=mysql-replica:3306"
      - "--mysqld.username=${MYSQL_EXPORTER_USERNAME}"
    ports:
      - "9104:9104"
    deploy:
      resources:
        limits:
          memory: {{ mysqld_exporter_memory_limit }}
    depends_on:
      mysql-replica:
        condition: service_healthy
    networks:
      - wiki-net

  # Phase 14-3: Kafka (KRaft 단일 브로커, ZooKeeper 불필요)
  kafka:
    image: {{ kafka_image }}
    container_name: wiki-kafka-prod
    restart: always
    hostname: kafka
    environment:
      # KRaft 단일 노드 설정
      KAFKA_NODE_ID: 1
      KAFKA_PROCESS_ROLES: broker,controller
      KAFKA_CONTROLLER_QUORUM_VOTERS: 1@kafka:9093
      KAFKA_LISTENERS: INTERNAL://0.0.0.0:9092,EXTERNAL://0.0.0.0:9094,CONTROLLER://0.0.0.0:9093
      KAFKA_ADVERTISED_LISTENERS: INTERNAL://kafka:9092,EXTERNAL://{{ hostvars['app-arm-2'].private_ip }}:9094
      KAFKA_LISTENER_SECURITY_PROTOCOL_MAP: INTERNAL:PLAINTEXT,EXTERNAL:PLAINTEXT,CONTROLLER:PLAINTEXT
      KAFKA_INTER_BROKER_LISTENER_NAME: INTERNAL
      KAFKA_CONTROLLER_LISTENER_NAMES: CONTROLLER
      KAFKA_INTER_BROKER_LISTENER_NAME: PLAINTEXT
      # 토픽 기본 설정
      KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR: 1
      KAFKA_TRANSACTION_STATE_LOG_REPLICATION_FACTOR: 1
      KAFKA_TRANSACTION_STATE_LOG_MIN_ISR: 1
      KAFKA_LOG_RETENTION_HOURS: {{ kafka_retention_hours }}
      KAFKA_LOG_RETENTION_BYTES: {{ kafka_retention_bytes }}
      CLUSTER_ID: {{ kafka_cluster_id }}
    ports:
      - "9092:9092"   # 내부 (같은 docker network)
      - "9094:9094"   # 외부 (서버 1 App에서 접근)
    volumes:
      - kafka_data:/var/lib/kafka/data
    deploy:
      resources:
        limits:
          memory: {{ kafka_memory_limit }}
    healthcheck:
      test: ["CMD-SHELL", "/opt/kafka/bin/kafka-broker-api-versions.sh --bootstrap-server localhost:9092 > /dev/null 2>&1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 60s
    networks:
      - wiki-net

  # Phase 14-3: Debezium Connect (MySQL binlog → Kafka)
  debezium-connect:
    image: {{ debezium_image }}
    container_name: wiki-debezium-prod
    restart: always
    environment:
      BOOTSTRAP_SERVERS: kafka:9092
      GROUP_ID: wiki-debezium
      CONFIG_STORAGE_TOPIC: _debezium_configs
      OFFSET_STORAGE_TOPIC: _debezium_offsets
      STATUS_STORAGE_TOPIC: _debezium_status
      CONFIG_STORAGE_REPLICATION_FACTOR: 1
      OFFSET_STORAGE_REPLICATION_FACTOR: 1
      STATUS_STORAGE_REPLICATION_FACTOR: 1
    ports:
      - "8083:8083"
    deploy:
      resources:
        limits:
          memory: {{ debezium_memory_limit }}
    depends_on:
      kafka:
        condition: service_healthy
    networks:
      - wiki-net

volumes:
  mysql_replica_data:
  kafka_data:
  lucene_index:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: /data/lucene

networks:
  wiki-net:
    driver: bridge
