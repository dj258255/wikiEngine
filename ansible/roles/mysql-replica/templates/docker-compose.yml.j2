# 서버 2: MySQL Replica + App 2 + Alloy (Phase 12~13)
# Phase 12: MySQL Replica (읽기 부하 분산)
# Phase 13: App 2 (CPU 부하 분산) + Alloy (로그 수집)

services:
  mysql-replica:
    image: {{ mysql_image }}
    container_name: wiki-mysql-replica
    restart: always
    environment:
      MYSQL_ROOT_PASSWORD: ${MYSQL_ROOT_PASSWORD}
    ports:
      - "3306:3306"
    volumes:
      - mysql_replica_data:/var/lib/mysql
    deploy:
      resources:
        limits:
          memory: {{ mysql_replica_memory_limit | default('4G') }}
    # Note: read-only/super-read-only는 초기화 완료 후 START REPLICA 시점에 SET GLOBAL로 활성화.
    # Docker entrypoint 초기화(root 비밀번호 설정)가 super-read-only와 충돌하므로 command에서 제외.
    command: >
      --character-set-server=utf8mb4
      --collation-server=utf8mb4_unicode_ci
      --innodb-buffer-pool-size=2G
      --performance-schema=ON
      --server-id=2
      --relay-log=relay-bin
      --log-replica-updates=ON
      --gtid-mode=ON
      --enforce-gtid-consistency=ON
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - wiki-net

  # Phase 13: App 2 (Lucene Replica 모드)
  app:
    image: {{ app_image }}
    container_name: wiki-app-prod-2
    restart: always
    env_file:
      - .env.prod
    ports:
      - "8080:8080"
    volumes:
      - lucene_index:/data/lucene
    deploy:
      resources:
        limits:
          memory: {{ app_memory_limit | default('2G') }}
    healthcheck:
      test: ["CMD", "curl", "-sf", "http://localhost:8080/actuator/health"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 120s
    depends_on:
      mysql-replica:
        condition: service_healthy
    networks:
      - wiki-net

  # Phase 13: Alloy (App 2 로그 → Loki) — TODO: alloy-config.alloy 템플릿 추가 후 활성화
  # alloy:
  #   image: {{ alloy_image | default('grafana/alloy:latest') }}
  #   container_name: wiki-alloy-prod-2
  #   restart: always
  #   volumes:
  #     - ./alloy-config.alloy:/etc/alloy/config.alloy:ro
  #     - /var/run/docker.sock:/var/run/docker.sock:ro
  #   command:
  #     - run
  #     - /etc/alloy/config.alloy
  #   deploy:
  #     resources:
  #       limits:
  #         memory: {{ alloy_memory_limit | default('128M') }}
  #   networks:
  #     - wiki-net

  mysql-exporter:
    image: {{ mysqld_exporter_image }}
    container_name: wiki-mysql-exporter-replica
    restart: always
    environment:
      MYSQLD_EXPORTER_PASSWORD: ${MYSQL_EXPORTER_PASSWORD}
    command:
      - "--mysqld.address=mysql-replica:3306"
      - "--mysqld.username=${MYSQL_EXPORTER_USERNAME}"
    ports:
      - "9104:9104"
    deploy:
      resources:
        limits:
          memory: {{ mysqld_exporter_memory_limit }}
    depends_on:
      mysql-replica:
        condition: service_healthy
    networks:
      - wiki-net

volumes:
  mysql_replica_data:
  lucene_index:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: /data/lucene

networks:
  wiki-net:
    driver: bridge
