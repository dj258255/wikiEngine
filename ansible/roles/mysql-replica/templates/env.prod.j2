# 서버 2 환경 변수 (Phase 12 MySQL Replica + Phase 13 App 2)
# {{ ansible_date_time.iso8601 }}

# MySQL Replica
MYSQL_ROOT_PASSWORD={{ db_root_password }}
MYSQL_EXPORTER_USERNAME={{ mysql_exporter_username }}
MYSQL_EXPORTER_PASSWORD={{ mysql_exporter_password }}

# --- Phase 13: App 2 ---

ENVIRONMENT=prod

# Database — Primary는 서버 1(원격), Replica는 로컬
DB_NAME={{ db_name }}
DB_USERNAME={{ db_username }}
DB_PASSWORD={{ db_password }}
DB_HOST={{ hostvars['app-arm'].private_ip }}
DB_PORT=3306
DB_PRIMARY_HOST={{ hostvars['app-arm'].private_ip }}
DB_REPLICA_HOST=mysql-replica
DB_PRIMARY_POOL_SIZE=2
DB_REPLICA_POOL_SIZE=15

# Flyway — App 2에서 비활성화 (App 1에서만 실행, Replication으로 스키마 전파)
FLYWAY_ENABLED=false

# JWT
JWT_SECRET={{ jwt_secret }}
JWT_EXPIRATION={{ jwt_expiration }}

# JPA
JPA_DDL_AUTO=validate
JPA_SHOW_SQL=false
HIBERNATE_BATCH_SIZE={{ hibernate_batch_size }}
HIBERNATE_STATISTICS={{ hibernate_statistics }}

# Cookie
COOKIE_SECURE={{ cookie_secure }}

# CORS
CORS_ALLOWED_ORIGINS={{ cors_allowed_origins }}

# Actuator
ACTUATOR_ENDPOINTS={{ actuator_endpoints }}
HEALTH_SHOW_DETAILS={{ health_show_details }}

# Lucene — Replica 모드 (IndexWriter 없음, rsync 동기화)
LUCENE_INDEX_PATH={{ lucene_index_path }}
LUCENE_BATCH_SIZE={{ lucene_batch_size }}
LUCENE_MODE=replica

# JVM
JAVA_OPTS={{ java_opts }}

# Tomcat
TOMCAT_MAX_THREADS={{ tomcat_max_threads | default(200) }}
TOMCAT_MIN_THREADS={{ tomcat_min_threads | default(10) }}
TOMCAT_ACCEPT_COUNT={{ tomcat_accept_count | default(100) }}

# Server
SERVER_PORT=8080

# Redis — 서버 1의 Redis (원격, private network)
REDIS_HOST={{ hostvars['app-arm'].private_ip }}
REDIS_PORT=6379
REDIS_PASSWORD={{ redis_password }}

# Logging
LOG_LEVEL={{ log_level }}
