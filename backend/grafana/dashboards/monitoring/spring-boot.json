{
  "uid": "wiki-spring-boot",
  "title": "Wiki Engine - Spring Boot",
  "tags": [
    "spring-boot",
    "wiki-engine",
    "monitoring"
  ],
  "timezone": "browser",
  "refresh": "15s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "HTTP 요청 - 평균 응답시간 (ms)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_sum{application=\"wiki-engine\"}[1m]) / rate(http_server_requests_seconds_count{application=\"wiki-engine\"}[1m]) * 1000",
          "legendFormat": "{{method}} {{uri}} [{{status}}]",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP 요청 처리량 (req/s)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"wiki-engine\"}[1m])) by (uri)",
          "legendFormat": "{{uri}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "HTTP 응답시간 P95 / P99 (ms)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"wiki-engine\"}[1m])) by (le)) * 1000",
          "legendFormat": "P95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{application=\"wiki-engine\"}[1m])) by (le)) * 1000",
          "legendFormat": "P99",
          "refId": "B"
        }
      ]
    },
    {
      "id": 4,
      "title": "HTTP 에러율 (4xx / 5xx)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {
            "mode": "palette-classic"
          },
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"wiki-engine\", status=~\"4..\"}[1m])) / sum(rate(http_server_requests_seconds_count{application=\"wiki-engine\"}[1m]))",
          "legendFormat": "4xx",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"wiki-engine\", status=~\"5..\"}[1m])) / sum(rate(http_server_requests_seconds_count{application=\"wiki-engine\"}[1m]))",
          "legendFormat": "5xx",
          "refId": "B"
        }
      ]
    },
    {
      "id": 10,
      "title": "JVM",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "collapsed": false
    },
    {
      "id": 5,
      "title": "JVM Heap 메모리 사용량",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 17
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{application=\"wiki-engine\", area=\"heap\"}",
          "legendFormat": "Used - {{id}}",
          "refId": "A"
        },
        {
          "expr": "jvm_memory_max_bytes{application=\"wiki-engine\", area=\"heap\"}",
          "legendFormat": "Max - {{id}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 6,
      "title": "GC 일시정지 시간",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 17
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{application=\"wiki-engine\"}[1m])",
          "legendFormat": "{{action}} - {{cause}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "title": "HikariCP",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 25
      },
      "collapsed": false
    },
    {
      "id": 7,
      "title": "HikariCP 커넥션 풀 상태",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 26
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "hikaricp_connections_active{application=\"wiki-engine\"}",
          "legendFormat": "Active",
          "refId": "A"
        },
        {
          "expr": "hikaricp_connections_idle{application=\"wiki-engine\"}",
          "legendFormat": "Idle",
          "refId": "B"
        },
        {
          "expr": "hikaricp_connections_pending{application=\"wiki-engine\"}",
          "legendFormat": "Pending",
          "refId": "C"
        },
        {
          "expr": "hikaricp_connections_max{application=\"wiki-engine\"}",
          "legendFormat": "Max",
          "refId": "D"
        }
      ]
    },
    {
      "id": 8,
      "title": "HikariCP 커넥션 획득 시간 (ms)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 26
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(hikaricp_connections_acquire_seconds_sum{application=\"wiki-engine\"}[1m]) / rate(hikaricp_connections_acquire_seconds_count{application=\"wiki-engine\"}[1m]) * 1000",
          "legendFormat": "Avg Acquire Time",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "title": "시스템",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 34
      },
      "collapsed": false
    },
    {
      "id": 9,
      "title": "프로세스 CPU 사용률",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 35
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {
            "mode": "palette-classic"
          },
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "process_cpu_usage{application=\"wiki-engine\"}",
          "legendFormat": "App CPU",
          "refId": "A"
        },
        {
          "expr": "system_cpu_usage{application=\"wiki-engine\"}",
          "legendFormat": "System CPU",
          "refId": "B"
        }
      ]
    },
    {
      "id": 13,
      "title": "JVM 스레드 수",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 35
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{application=\"wiki-engine\"}",
          "legendFormat": "Live",
          "refId": "A"
        },
        {
          "expr": "jvm_threads_peak_threads{application=\"wiki-engine\"}",
          "legendFormat": "Peak",
          "refId": "B"
        },
        {
          "expr": "jvm_threads_daemon_threads{application=\"wiki-engine\"}",
          "legendFormat": "Daemon",
          "refId": "C"
        }
      ]
    },
    {
      "id": 14,
      "title": "Caffeine Cache",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 43
      },
      "collapsed": false
    },
    {
      "id": 15,
      "title": "Cache Hit Rate (%)",
      "type": "gauge",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 44
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.5
              },
              {
                "color": "yellow",
                "value": 0.8
              },
              {
                "color": "green",
                "value": 0.95
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "sum by (cache) (rate(cache_gets_total{application=\"wiki-engine\", result=\"hit\"}[5m])) / sum by (cache) (rate(cache_gets_total{application=\"wiki-engine\"}[5m]))",
          "legendFormat": "{{cache}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 16,
      "title": "Cache Gets (hit / miss per sec)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 44
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (cache, result) (rate(cache_gets_total{application=\"wiki-engine\"}[1m]))",
          "legendFormat": "{{cache}} - {{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 17,
      "title": "Cache Size (현재 엔트리 수)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 52
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "cache_size{application=\"wiki-engine\"}",
          "legendFormat": "{{cache}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 18,
      "title": "Cache Evictions (per sec)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 52
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (cache) (rate(cache_evictions_total{application=\"wiki-engine\"}[1m]))",
          "legendFormat": "{{cache}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 19,
      "title": "── AI 요약 (Phase 21: RAG + Gemini) ──",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 60
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 20,
      "title": "LLM 호출 수 (RPM)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 61
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "rpm",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(gen_ai_client_operation_seconds_count{application=\"wiki-engine\"}[5m]) * 60",
          "legendFormat": "{{gen_ai_request_model}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 21,
      "title": "LLM 응답시간 (ms)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 61
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(gen_ai_client_operation_seconds_sum{application=\"wiki-engine\"}[5m]) / rate(gen_ai_client_operation_seconds_count{application=\"wiki-engine\"}[5m]) * 1000",
          "legendFormat": "avg",
          "refId": "A"
        },
        {
          "expr": "gen_ai_client_operation_seconds_max{application=\"wiki-engine\"} * 1000",
          "legendFormat": "max",
          "refId": "B"
        }
      ]
    },
    {
      "id": 22,
      "title": "토큰 사용량 (per min)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 61
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(gen_ai_client_token_usage_total{application=\"wiki-engine\", gen_ai_token_type=\"input\"}[5m]) * 60",
          "legendFormat": "input tokens/min",
          "refId": "A"
        },
        {
          "expr": "rate(gen_ai_client_token_usage_total{application=\"wiki-engine\", gen_ai_token_type=\"output\"}[5m]) * 60",
          "legendFormat": "output tokens/min",
          "refId": "B"
        }
      ]
    },
    {
      "id": 23,
      "title": "AI 요약 피드백",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 69
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "thumbs up"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "thumbs down"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "increase(ai_summary_feedback_total{application=\"wiki-engine\", rating=\"up\"}[1h])",
          "legendFormat": "thumbs up",
          "refId": "A"
        },
        {
          "expr": "increase(ai_summary_feedback_total{application=\"wiki-engine\", rating=\"down\"}[1h])",
          "legendFormat": "thumbs down",
          "refId": "B"
        }
      ]
    },
    {
      "id": 24,
      "title": "일별 누적 토큰",
      "type": "stat",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 69
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "increase(gen_ai_client_token_usage_total{application=\"wiki-engine\", gen_ai_token_type=\"input\"}[24h])",
          "legendFormat": "Input (24h)",
          "refId": "A"
        },
        {
          "expr": "increase(gen_ai_client_token_usage_total{application=\"wiki-engine\", gen_ai_token_type=\"output\"}[24h])",
          "legendFormat": "Output (24h)",
          "refId": "B"
        }
      ]
    },
    {
      "id": 25,
      "title": "일별 비용 추정 ($)",
      "description": "Gemini 2.0 Flash: input $0.10/1M, output $0.40/1M",
      "type": "stat",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 69
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "increase(gen_ai_client_token_usage_total{application=\"wiki-engine\", gen_ai_token_type=\"input\"}[24h]) * 0.0000001 + increase(gen_ai_client_token_usage_total{application=\"wiki-engine\", gen_ai_token_type=\"output\"}[24h]) * 0.0000004",
          "legendFormat": "Estimated Cost (24h)",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39
}